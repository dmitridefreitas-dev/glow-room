# =============================================================================
# THE GLOW ROOM — ENV TEMPLATE (safe to commit; placeholders only)
# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored and must NEVER be committed.
# =============================================================================

# ---- Supabase ----
SUPABASE_DB_PASSWORD=your-db-password
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key            # public / client-safe
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key        # SERVER ONLY — never expose to client

# ---- Stripe ----
STRIPE_SECRET_KEY=sk_test_xxx                          # use sk_test_ while building
STRIPE_PUBLISHABLE_KEY=pk_test_xxx                      # use pk_test_ while building
STRIPE_WEBHOOK_SECRET=whsec_xxx                         # created in Phase 4 (or via Stripe CLI locally)

# ---- Email (Resend) ----
RESEND_API_KEY=re_xxx

# ---- Discord ----
DISCORD_BOT_TOKEN=your-bot-token
DISCORD_GUILD_ID=your-guild-id
DISCORD_MEMBER_ROLE_ID=your-member-role-id
DISCORD_SHARED_SECRET=random-long-hex                  # signs bot <-> api calls

# ---- Push / Analytics / Monitoring ----
ONESIGNAL_APP_ID=your-onesignal-app-id
ONESIGNAL_API_KEY=your-onesignal-rest-api-key          # SERVER ONLY
NEXT_PUBLIC_POSTHOG_KEY=phc_xxx                        # public / client-safe
SENTRY_DSN=https://xxx.ingest.sentry.io/xxx            # public / client-safe

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000              # dev; point to domain near launch
